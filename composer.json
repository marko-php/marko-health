{
    "name": "marko/health",
    "description": "Health check interfaces and infrastructure for Marko Framework",
    "license": "MIT",
    "type": "marko-module",
    "require": {
        "php": "^8.5",
        "marko/core": "self.version",
        "marko/config": "self.version",
        "marko/routing": "self.version"
    },
    "require-dev": {
        "pestphp/pest": "^4.0",
        "marko/testing": "self.version"
    },
    "autoload": {
        "psr-4": {
            "Marko\\Health\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\Health\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "marko": {
            "module": true
        }
    }
}
